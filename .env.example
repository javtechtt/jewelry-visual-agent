# ---------------------------------------------------------------------------
# Aurelis — environment variables
# Copy this file to .env.local and fill in values. .env.local is gitignored.
# ---------------------------------------------------------------------------

# OpenAI Realtime API key. SERVER-SIDE ONLY — never exposed to the browser.
# Used by app/api/realtime-session/route.ts to mint ephemeral sessions.
# If left blank, the app gracefully falls back to browser speech / text input.
OPENAI_API_KEY=

# Target Realtime model. Public (NEXT_PUBLIC_) so the client can label the
# status and negotiate the WebRTC connection.
NEXT_PUBLIC_REALTIME_MODEL=gpt-realtime-2
